# Database (automatically set by docker-compose for the app service)
DATABASE_URL=postgresql://postgres:postgres@db:5432/familyhealth

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-strong-random-secret

# Public URL of the app (used by NextAuth for redirects)
AUTH_URL=http://localhost:3000

# SMTP — leave blank to log email links to console instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Family Health <no-reply@example.com>"

# Public base URL used to build email links
APP_URL=http://localhost:3000

# Admin user bootstrapped on first startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
