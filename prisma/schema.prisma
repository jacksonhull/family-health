generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMINISTRATOR
  USER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum SharePermission {
  READ
  WRITE
}

enum EventCategory {
  APPOINTMENT      // doctor/specialist visits
  DIAGNOSIS        // diagnoses and conditions
  MEDICATION       // prescriptions, changes, stops
  PROCEDURE        // surgeries, tests, treatments
  VACCINATION      // immunisations
  MEASUREMENT      // weight, BP, blood sugar, etc.
  SYMPTOM          // onset/resolution of symptoms
  ALLERGY          // allergy identification
  OTHER
}

model User {
  id           String     @id @default(cuid())
  email        String?    @unique          // optional — minors may not have one
  name         String?
  dateOfBirth  DateTime?
  timezone     String     @default("UTC")  // IANA tz, e.g. "America/New_York"
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  passwordHash String?                     // null until invite is accepted
  createdAt    DateTime   @default(now())

  invite                 Invite?
  sentInvites            Invite[]             @relation("InvitedBy")
  passwordResetTokens    PasswordResetToken[]
  dataSharesAsOwner      DataShare[]          @relation("Owner")
  dataSharesAsSharedWith DataShare[]          @relation("SharedWith")
  timelineEntries        TimelineEntry[]
  medicalHistories       MedicalHistory[]
}

model Invite {
  id          String   @id @default(cuid())
  userId      String   @unique            // one pending invite per user
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  invitedById String
  invitedBy   User     @relation("InvitedBy", fields: [invitedById], references: [id])
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model DataShare {
  id           String          @id @default(cuid())
  ownerId      String
  owner        User            @relation("Owner", fields: [ownerId], references: [id], onDelete: Cascade)
  sharedWithId String
  sharedWith   User            @relation("SharedWith", fields: [sharedWithId], references: [id], onDelete: Cascade)
  permission   SharePermission
  createdAt    DateTime        @default(now())

  @@unique([ownerId, sharedWithId])
}

// Generic key/value store for application settings
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// An Event is the "what" — reusable detail record
model Event {
  id          String        @id @default(cuid())
  title       String
  summary     String?       // concise overview; manually entered or AI-generated
  description String?       // detailed notes
  category    EventCategory @default(OTHER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  timelineEntries TimelineEntry[]
  details         EventDetail[]
}

// Attached detail for an event — text, file, image, transcript, etc.
// The AI determines the document type rather than using a fixed enum.
model EventDetail {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  sourceType   String   // "text" | "file"
  originalText String?  // pasted text, or text extracted from an uploaded file
  fileName     String?  // original filename for uploaded files
  filePath     String?  // path relative to UPLOAD_DIR for binary files
  mimeType     String?  // MIME type of uploaded file

  // AI-populated fields
  documentType String?  // flexible label inferred by the LLM
  processed    Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Versioned medical history summaries for a family member.
// The most-recent record is injected into AI prompts as patient context.
model MedicalHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary   String   // free-text narrative; manually written or AI-updated
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// A TimelineEntry is the "who + when" — links a member to an event
model TimelineEntry {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  startTime DateTime              // stored in UTC
  endTime   DateTime?             // null = point-in-time event
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, startTime])   // efficient per-member chronological queries
  @@index([startTime])           // efficient cross-member range queries
}
